# Configurações do Servidor SSH
SSH_HOST=seu-servidor.com
SSH_PORT=22
SSH_USER=seu-usuario
SSH_PASSWORD=sua-senha
# Ou use chave SSH (recomendado)
# SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# Configurações do Docker
DOCKER_IMAGE_NAME=meusite
DOCKER_IMAGE_TAG=latest
DOCKER_CONTAINER_NAME=meusite-app

# Diretório remoto onde os arquivos serão colocados
REMOTE_DEPLOY_DIR=/home/meunik/docker/meusite

# Configurações da aplicação (para docker-compose)
PORT=8080
DOMAIN=seudominio.com

# Git (opcional - para versionamento)
GIT_EMAIL=seu-email@exemplo.com
GIT_USER=Seu Nome
